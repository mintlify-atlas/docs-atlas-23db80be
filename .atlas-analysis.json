  "keyFeatures": [
    "Multi-package architecture with Core, main, and ASP.NET Core packages",
    "Client SDK for connecting to any MCP server",
    "Server SDK with attribute-based tool, prompt, and resource discovery",
    "Multiple transport options: stdio, HTTP, and SSE",
    "Integration with Microsoft.Extensions.AI for seamless LLM usage",
    "Dependency injection and hosting support",
    "OAuth authentication support",
    "Progress tracking and cancellation",
    "Native AOT compatibility"
  ],
  "publicApiSurface": [
    "McpClient - Client for connecting to MCP servers",
    "McpServer - Base server implementation",
    "McpSession - Session management",
    "StdioClientTransport - Stdio transport for clients",
    "HttpClientTransport - HTTP transport for clients",
    "AddMcpServer() - DI extension for server setup",
    "[McpServerTool] - Attribute for marking tool methods",
    "[McpServerPrompt] - Attribute for marking prompt methods",
    "[McpServerResource] - Attribute for marking resource methods",
    "McpServerBuilderExtensions - Extensions for server configuration",
    "MapMcp() - ASP.NET Core endpoint mapping",
    "ClientOAuthProvider - OAuth authentication provider",
    "McpSessionHandler - Request/notification handler base class",
    "Protocol types (Tool, Prompt, Resource, etc.)",
    "UriTemplate - URI template matching for resources"
  ]
}
